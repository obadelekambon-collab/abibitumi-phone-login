<?xml version="1.0" encoding="UTF-8"?>
<phpunit
	bootstrap="bootstrap.php"
	colors="true"
	backupGlobals="false"
	beStrictAboutTestsThatDoNotTestAnything="true"
>
	<testsuites>
		<testsuite name="Abibitumi Chat WordPress integration">
			<directory suffix=".php">cases</directory>
		</testsuite>
	</testsuites>
</phpunit>
