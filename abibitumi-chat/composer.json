{
	"name": "abibitumi/abibitumi-chat",
	"description": "Self-hosted live chat, chatbot, ticketing, and PWA plugin for WordPress.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=7.4",
		"ext-curl": "*",
		"ext-json": "*",
		"ext-mbstring": "*",
		"ext-openssl": "*",
		"minishlink/web-push": "^7.0"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6",
		"wp-phpunit/wp-phpunit": "^6.9",
		"yoast/phpunit-polyfills": "^1.1"
	},
	"config": {
		"allow-plugins": false,
		"optimize-autoloader": true,
		"platform": {
			"php": "7.4.33"
		},
		"sort-packages": true
	},
	"scripts": {
		"test:integration": "phpunit -c tests/integration/phpunit.xml.dist"
	}
}
